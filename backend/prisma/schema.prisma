generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum Seniority {
  NOT_SELECTED
  STUDENDT
  JUNIOR
  PLENO
  SENIOR
  TECH_LEAD
  C_LEVEL
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  user_name       String   @unique
  user_photo      String?
  hashed_password String
  createdAt       DateTime @default(now()) @db.Timestamp(3)
  seniority_id    Seniority @default(NOT_SELECTED)

  posts         Post[]
  likesPosts    Likes_Posts[]
  postsSaves    Posts_Saves[]
  likesComments Likes_Comments[]
}

model Post {
  id        String   @id @default(uuid())
  title     String
  anonymous Boolean
  views     Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamp(3)

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  snippets   Snippet[]
  comments   Comment[]
  languages  Languages_posts[]
  likesPosts Likes_Posts[]
  postsSaves Posts_Saves[]
}

model Language {
  id   Int    @id @default(autoincrement()) @db.SmallInt
  name String

  snippets Snippet[]
  posts    Languages_posts[]
}

model Languages_posts {
  post_id     String
  language_id Int    @db.SmallInt

  post     Post     @relation(fields: [post_id], references: [id])
  language Language @relation(fields: [language_id], references: [id])

  @@id([post_id, language_id])
}

model Snippet {
  id      String @id @default(uuid())
  content String

  post_id     String
  language_id Int    @db.SmallInt

  post     Post     @relation(fields: [post_id], references: [id])
  language Language @relation(fields: [language_id], references: [id])
}

model Comment {
  id                String   @id @default(uuid())
  post_id           String
  parent_comment_id String?
  data_criacao      DateTime @default(now())
  conteudo          String

  post          Post             @relation(fields: [post_id], references: [id])
  parent        Comment?         @relation("CommentToComment", fields: [parent_comment_id], references: [id])
  replies       Comment[]        @relation("CommentToComment")
  likesComments Likes_Comments[]
}

model Likes_Posts {
  post_id String
  user_id String
  is_like Boolean

  post Post @relation(fields: [post_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  @@id([post_id, user_id])
}

model Posts_Saves {
  post_id String
  user_id String

  post Post @relation(fields: [post_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  @@id([post_id, user_id])
}

model Likes_Comments {
  comment_id String
  user_id    String
  is_like    Boolean

  comment Comment @relation(fields: [comment_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@id([comment_id, user_id])
}
