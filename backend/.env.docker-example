# ================================
# EXAMPLE PLACEHOLDER ENV FILE
# ================================

# URL de conexão com o banco (usado pelo NestJS / Prisma)
# Substitua 'examplepassword' e 'exampledb' conforme necessário
DATABASE_URL="postgresql://exampleuser:examplepassword@db:5432/exampledb"

# Credenciais do PostgreSQL (usado pelo container)
# Substitua se quiser nomes diferentes para dev local
POSTGRES_USER=exampleuser
POSTGRES_PASSWORD=examplepassword
POSTGRES_DB=exampledb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=sua_senha_aqui

# OAuth Github
GITHUB_CLIENT_ID=example
GITHUB_CLIENT_SECRET=example

# OAuth Google
GOOGLE_CLIENT_ID=example
GOOGLE_CLIENT_SECRET=example

# Token JWT
JWT_ACCESS_SECRET=example
JWT_REFRESH_SECRET=example
JWT_ACCESS_TTL=example
JWT_REFRESH_TTL=example

# Porta da aplicação NestJS
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173/